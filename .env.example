# PNG Compliance Hub 2026 — Environment Configuration Example

# Django Settings
DEBUG=True
SECRET_KEY=django-insecure-png-compliance-hub-2026-default-key-replace-in-prod
ALLOWED_HOSTS=localhost,127.0.0.1

# Database Configuration
# Default uses SQLite for development if DATABASE_URL is empty
# Format: postgres://user:password@host:port/dbname
DATABASE_URL=sqlite:///db.sqlite3

# IRC Settings
TAX_YEAR=2026
GST_RATE=0.10
SBT_THRESHOLD=250000

# Optional Production DB Settings
DB_NAME=png_compliance_hub
DB_USER=postgres
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=5432
